{
  "name": "compufest2026-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "umami:up": "docker compose --env-file infra/umami/.env -f infra/umami/docker-compose.yml up -d",
    "umami:down": "docker compose --env-file infra/umami/.env -f infra/umami/docker-compose.yml down",
    "umami:logs": "docker compose --env-file infra/umami/.env -f infra/umami/docker-compose.yml logs -f umami",
    "load:smoke": "TEST_TYPE=smoke k6 run tests/load/website-load.k6.js",
    "load:stress": "TEST_TYPE=stress k6 run tests/load/website-load.k6.js",
    "load:spike": "TEST_TYPE=spike k6 run tests/load/website-load.k6.js"
  },
  "dependencies": {
    "@leenguyen/react-flip-clock-countdown": "^1.7.2",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/rapier": "^2.2.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "@types/three": "^0.183.1",
    "@use-gesture/react": "^10.3.1",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "gsap": "^3.14.2",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "qss": "^3.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router-dom": "^7.13.2",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
